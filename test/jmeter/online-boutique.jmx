                <collectionProp name="Arguments.arguments">
                  <elementProp name="currency_code" elementType="HTTPArgument"><boolProp name="HTTPArgument.always_encode">false</boolProp><stringProp name="Argument.value">JPY</stringProp><stringProp name="Argument.metadata">=</stringProp><boolProp name="HTTPArgument.use_equals">true</boolProp><stringProp name="Argument.name">currency_code</stringProp></elementProp>
