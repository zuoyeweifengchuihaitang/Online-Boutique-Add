              <stringProp name="script"><![CDATA[
def basePath = vars.get('base_path') ?: ''
def productId = vars.get('product_id') ?: 'OLJCESPC7Z'
def joinPath = { b, p -> !b ? p : (b.endsWith('/') && p.startsWith('/') ? b.substring(0, b.length() - 1) + p : (!b.endsWith('/') && !p.startsWith('/') ? b + '/' + p : b + p)) }
vars.put('product_detail_path', joinPath(basePath, props.get('product_detail_path_template', '/product/${product_id}').replace('${product_id}', productId)))
vars.put('review_fragment_path', joinPath(basePath, props.get('review_fragment_path_template', '/reviews/${product_id}').replace('${product_id}', productId)))
]]></stringProp>
            </JSR223PreProcessor>
