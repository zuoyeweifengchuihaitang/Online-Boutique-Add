          <elementProp name="review_rating" elementType="Argument"><stringProp name="Argument.name">review_rating</stringProp><stringProp name="Argument.value">${__P(review_rating,5)}</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
          <elementProp name="review_user_prefix" elementType="Argument"><stringProp name="Argument.name">review_user_prefix</stringProp><stringProp name="Argument.value">${__P(review_user_prefix,jmeter-user)}</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
          <elementProp name="review_title_prefix" elementType="Argument"><stringProp name="Argument.name">review_title_prefix</stringProp><stringProp name="Argument.value">${__P(review_title_prefix,jmeter-review)}</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
          <elementProp name="review_content_prefix" elementType="Argument"><stringProp name="Argument.name">review_content_prefix</stringProp><stringProp name="Argument.value">${__P(review_content_prefix,automated-performance-test)}</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
          <elementProp name="review_submit_path" elementType="Argument"><stringProp name="Argument.name">review_submit_path</stringProp><stringProp name="Argument.value">${__P(review_submit_path,/reviews)}</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
          <elementProp name="review_direct_enabled" elementType="Argument"><stringProp name="Argument.name">review_direct_enabled</stringProp><stringProp name="Argument.value">${__P(review_direct_enabled,false)}</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
