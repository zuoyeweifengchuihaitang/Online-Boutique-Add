            <stringProp name="RandomTimer.range">${__groovy(Math.max(0\, (props.get('think_time_max_ms'\,'3000') as int) - (props.get('think_time_min_ms'\,'1000') as int)))}</stringProp>
          </UniformRandomTimer>
