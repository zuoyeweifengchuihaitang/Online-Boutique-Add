            <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert T04 HTTP 200" enabled="true"><collectionProp name="Asserion.test_strings"><stringProp name="200">200</stringProp></collectionProp><stringProp name="Assertion.test_field">Assertion.response_code</stringProp><boolProp name="Assertion.assume_success">false</boolProp><intProp name="Assertion.test_type">8</intProp></ResponseAssertion>
            <hashTree/>
            <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Assert T04 cart content" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp><stringProp name="parameters"></stringProp><stringProp name="filename"></stringProp><stringProp name="cacheKey">t04_cart_content</stringProp>
              <stringProp name="script"><![CDATA[
def body = prev.getResponseDataAsString()
def productId = vars.get('product_id')
def missing = []
if (!body.contains('Cart (')) missing << 'Cart ('
if (!body.contains('SKU #' + productId)) missing << 'SKU #' + productId
if (!body.contains('Quantity: 1')) missing << 'Quantity: 1'
if (!body.contains('Total')) missing << 'Total'
if (body.contains('Your shopping cart is empty!')) missing << 'not empty cart'
if (missing) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage('Page content assertion failed: T04 missing ' + missing.join(', '))
}
]]></stringProp>
            </JSR223Assertion>
            <hashTree/>
          </hashTree>

          <IfController guiclass="IfControllerPanel" testclass="IfController" testname="If currency percent" enabled="true">
            <stringProp name="IfController.condition">${__groovy(new java.util.Random().nextInt(100) &lt; (props.get('currency_percent'\,'20') as int))}</stringProp>
