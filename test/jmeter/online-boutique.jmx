            <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert T01 HTTP 200" enabled="true"><collectionProp name="Asserion.test_strings"><stringProp name="200">200</stringProp></collectionProp><stringProp name="Assertion.test_field">Assertion.response_code</stringProp><boolProp name="Assertion.assume_success">false</boolProp><intProp name="Assertion.test_type">8</intProp></ResponseAssertion>
            <hashTree/>
            <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Assert T01 page content" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp><stringProp name="parameters"></stringProp><stringProp name="filename"></stringProp><stringProp name="cacheKey">t01_page_content</stringProp>
              <stringProp name="script"><![CDATA[
def body = prev.getResponseDataAsString()
def missing = []
if (!body?.trim()) missing << 'non-empty response'
if (!body.contains('Hot Products')) missing << 'Hot Products'
if (body.contains('Something has failed') || body.contains('Uh, oh!')) missing << 'not error template'
if (missing) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage('Page content assertion failed: T01 missing ' + missing.join(', '))
}
]]></stringProp>
            </JSR223Assertion>
            <hashTree/>
          </hashTree>

          <UniformRandomTimer guiclass="UniformRandomTimerGui" testclass="UniformRandomTimer" testname="Think Time" enabled="true">
            <stringProp name="ConstantTimer.delay">${think_time_min_ms}</stringProp>
            <stringProp name="RandomTimer.range">${__groovy(Math.max(0\, (props.get('think_time_max_ms'\,'3000') as int) - (props.get('think_time_min_ms'\,'1000') as int)))}</stringProp>
          </UniformRandomTimer>
          <hashTree/>

          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="T02_Product_Detail_With_Reviews" enabled="true">
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments"><collectionProp name="Arguments.arguments"/></elementProp>
            <stringProp name="HTTPSampler.path">${product_detail_path}</stringProp>
            <stringProp name="HTTPSampler.method">GET</stringProp>
            <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
            <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
            <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
            <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
          </HTTPSamplerProxy>
          <hashTree>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Prepare product and review paths" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp><stringProp name="parameters"></stringProp><stringProp name="filename"></stringProp><stringProp name="cacheKey">prepare_paths</stringProp>
              <stringProp name="script"><![CDATA[
def joinPath = { b, p ->
    b = b ?: ''
    p = p ?: ''
    if (!b) return p
    if (b.endsWith('/') && p.startsWith('/')) return b.substring(0, b.length() - 1) + p
    if (!b.endsWith('/') && !p.startsWith('/')) return b + '/' + p
    return b + p
}
def productId = vars.get('product_id') ?: 'OLJCESPC7Z'
def productTemplate = props.get('product_detail_path_template', '/product/${product_id}')
def reviewTemplate = props.get('review_fragment_path_template', '/reviews/${product_id}')
vars.put('product_detail_path', joinPath(vars.get('base_path'), productTemplate.replace('${product_id}', productId)))
vars.put('review_fragment_path', joinPath(vars.get('base_path'), reviewTemplate.replace('${product_id}', productId)))
]]></stringProp>
            </JSR223PreProcessor>
            <hashTree/>
            <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert T02 HTTP 200" enabled="true"><collectionProp name="Asserion.test_strings"><stringProp name="200">200</stringProp></collectionProp><stringProp name="Assertion.test_field">Assertion.response_code</stringProp><boolProp name="Assertion.assume_success">false</boolProp><intProp name="Assertion.test_type">8</intProp></ResponseAssertion>
            <hashTree/>
            <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Assert T02 product and review page" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp><stringProp name="parameters"></stringProp><stringProp name="filename"></stringProp><stringProp name="cacheKey">t02_page_content</stringProp>
              <stringProp name="script"><![CDATA[
def body = prev.getResponseDataAsString()
def productId = vars.get('product_id')
def missing = []
if (!body.contains('Customer Reviews')) missing << 'Customer Reviews'
if (!body.contains('Write a Review')) missing << 'Write a Review'
if (!body.contains('Add To Cart')) missing << 'Add To Cart'
if (!body.contains(productId)) missing << 'product id ' + productId
if (body.contains('Something has failed') || body.contains('Uh, oh!')) missing << 'not error template'
if (missing) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage('Page content assertion failed: T02 missing ' + missing.join(', '))
}
]]></stringProp>
            </JSR223Assertion>
            <hashTree/>
          </hashTree>

          <UniformRandomTimer guiclass="UniformRandomTimerGui" testclass="UniformRandomTimer" testname="Think Time" enabled="true">
