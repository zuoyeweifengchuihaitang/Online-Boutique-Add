                <stringProp name="scriptLanguage">groovy</stringProp><stringProp name="parameters"></stringProp><stringProp name="filename"></stringProp><stringProp name="cacheKey">t08_write_product_page</stringProp>
                <stringProp name="script"><![CDATA[
def body = prev.getResponseDataAsString()
def missing = []
if (!body.contains('Customer Reviews')) missing << 'Customer Reviews'
if (!body.contains(vars.get('review_title'))) missing << 'review_title'
if (!body.contains(vars.get('review_user_name'))) missing << 'review_user_name'
if (!body.contains(vars.get('review_content'))) missing << 'review_content'
if (missing) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage('Page content assertion failed: T08 missing ' + missing.join(', '))
}
]]></stringProp>
