              <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
              <elementProp name="HTTPsampler.Arguments" elementType="Arguments"><collectionProp name="Arguments.arguments"><elementProp name="" elementType="HTTPArgument"><boolProp name="HTTPArgument.always_encode">false</boolProp><stringProp name="Argument.value">{&quot;product_id&quot;:&quot;${product_id}&quot;,&quot;user_name&quot;:&quot;${review_user_name}&quot;,&quot;rating&quot;:${review_rating},&quot;title&quot;:&quot;${review_title}&quot;,&quot;content&quot;:&quot;${review_content}&quot;}</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp></collectionProp></elementProp>
              <stringProp name="HTTPSampler.path">${base_path}${review_submit_path}</stringProp>
              <stringProp name="HTTPSampler.method">POST</stringProp>
              <boolProp name="HTTPSampler.follow_redirects">true</boolProp><boolProp name="HTTPSampler.auto_redirects">false</boolProp><boolProp name="HTTPSampler.use_keepalive">true</boolProp><boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
            </HTTPSamplerProxy>
            <hashTree>
              <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Prepare review data" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp><stringProp name="parameters"></stringProp><stringProp name="filename"></stringProp><stringProp name="cacheKey">prepare_review_data_write</stringProp>
                <stringProp name="script"><![CDATA[
def runId = vars.get('run_id') ?: props.get('run_id', 'LOCAL')
def thread = ctx.getThreadNum()
def uuid = java.util.UUID.randomUUID().toString()
vars.put('review_user_name', "${vars.get('review_user_prefix')}-${runId}-${thread}")
vars.put('review_title', "${vars.get('review_title_prefix')}-${runId}-${uuid}")
vars.put('review_content', "${vars.get('review_content_prefix')}-${runId}-${uuid}")
]]></stringProp>
              </JSR223PreProcessor>
              <hashTree/>
              <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="JSON Content-Type" enabled="true"><collectionProp name="HeaderManager.headers"><elementProp name="" elementType="Header"><stringProp name="Header.name">Content-Type</stringProp><stringProp name="Header.value">application/json</stringProp></elementProp></collectionProp></HeaderManager>
              <hashTree/>
              <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert T06 write HTTP 201" enabled="true"><collectionProp name="Asserion.test_strings"><stringProp name="201">201</stringProp></collectionProp><stringProp name="Assertion.test_field">Assertion.response_code</stringProp><boolProp name="Assertion.assume_success">false</boolProp><intProp name="Assertion.test_type">8</intProp></ResponseAssertion>
              <hashTree/>
              <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Extract review_id" enabled="true"><stringProp name="JSONPostProcessor.referenceNames">review_id</stringProp><stringProp name="JSONPostProcessor.jsonPathExprs">$.id</stringProp><stringProp name="JSONPostProcessor.match_numbers">1</stringProp><stringProp name="JSONPostProcessor.defaultValues">NOT_FOUND</stringProp></JSONPostProcessor>
              <hashTree/>
              <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Assert T06 write JSON" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp><stringProp name="parameters"></stringProp><stringProp name="filename"></stringProp><stringProp name="cacheKey">t06_write_json</stringProp>
                <stringProp name="script"><![CDATA[
import groovy.json.JsonSlurper
def json
try { json = new JsonSlurper().parseText(prev.getResponseDataAsString()) } catch (Throwable t) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage('JSON assertion failed: response is not valid JSON: ' + t.message)
    return
}
def errors = []
if (!json.id) errors << 'id'
if (json.product_id != vars.get('product_id')) errors << 'product_id'
if (json.user_name != vars.get('review_user_name')) errors << 'user_name'
if ((json.rating as Integer) != (vars.get('review_rating') as Integer)) errors << 'rating'
if (json.title != vars.get('review_title')) errors << 'title'
if (json.content != vars.get('review_content')) errors << 'content'
if (!json.created_at) errors << 'created_at'
if (errors) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage('JSON assertion failed: T06 invalid fields ' + errors.join(', '))
}
]]></stringProp>
              </JSR223Assertion>
              <hashTree/>
            </hashTree>

