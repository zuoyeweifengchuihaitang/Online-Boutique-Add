          <elementProp name="review_cleanup_enabled" elementType="Argument"><stringProp name="Argument.name">review_cleanup_enabled</stringProp><stringProp name="Argument.value">${__P(review_cleanup_enabled,false)}</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
