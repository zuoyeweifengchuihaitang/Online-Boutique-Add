                <stringProp name="scriptLanguage">groovy</stringProp><stringProp name="parameters"></stringProp><stringProp name="filename"></stringProp><stringProp name="cacheKey">t05_currency_content</stringProp>
                <stringProp name="script"><![CDATA[
def body = prev.getResponseDataAsString()
if (!body.contains('JPY') || !body.contains('Hot Products')) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage('Page content assertion failed: T05 expected JPY and Hot Products after currency change')
}
]]></stringProp>
